# Copier en `.env` et compléter.

# Base de données (SQLite en local, PostgreSQL en production)
DATABASE_URL="file:./dev.db"

NEXTAUTH_SECRET=""

# Téléphonie (Twilio / Vonage)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# IA / LLM (configurable par agent)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
MISTRAL_API_KEY=""

# Voix (STT / TTS)
DEEPGRAM_API_KEY=""
ELEVENLABS_API_KEY=""

# URLs publiques
PUBLIC_URL="http://localhost:3000"
VOICE_SERVER_WS_URL="ws://localhost:4000"
