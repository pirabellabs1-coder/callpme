# --- Callpme — variables d'environnement de PRODUCTION (Vercel) ---
# Copiez ces clés dans Vercel → Project → Settings → Environment Variables.
# NE COMMITTEZ JAMAIS les vraies valeurs.

# Base de données PostgreSQL (Vercel Postgres / Neon / Supabase)
# Exemple Neon : postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/callpme?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/callpme?sslmode=require"

# Secret de session (générer : openssl rand -hex 32)
NEXTAUTH_SECRET="CHANGEZ_MOI_32_OCTETS_ALEATOIRES"

# URL publique du site déployé (sans slash final)
PUBLIC_URL="https://votre-domaine.com"

# E-mail (Resend) — adresse d'un domaine vérifié
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Callpme <noreply@votre-domaine.com>"

# Voix premium (optionnel — audio réel)
ELEVENLABS_API_KEY=""
CARTESIA_API_KEY=""
OPENAI_API_KEY=""

# LLM (optionnel — sinon moteur local)
ANTHROPIC_API_KEY=""
MISTRAL_API_KEY=""

# Téléphonie (Phase 3, optionnel)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
DEEPGRAM_API_KEY=""
